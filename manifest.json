{
  "manifest_version": 3,
  "name": "Key Sound",
  "version": "2.0",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sound/*/*.wav"],
      "matches": ["<all_urls>"]
    }
  ]
}
